@page "/app/{Slug}"
@rendermode InteractiveServer
@inject UpdateService Updates
@inject NavigationManager Nav
@using AppUpdateServer.Services

<PageTitle>@(_app?.Name ?? Slug) — App Update Server</PageTitle>

@if (_app is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <div>
            <MudText Typo="Typo.h4">@_app.Name</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">@_app.Slug</MudText>
        </div>
        <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="DeleteApp">
            Delete App
        </MudButton>
    </MudStack>

    <MudAlert Severity="Severity.Info" Class="mb-4">
        <MudText><strong>POST</strong> /api/update — version check (public)</MudText>
        <MudText><strong>GET</strong> /api/update/download/@_app.Slug/{version} — download (public)</MudText>
    </MudAlert>

    <!-- Upload -->
    <MudPaper Class="pa-6 mb-4">
        <MudText Typo="Typo.h6" Class="mb-4">Upload New Version</MudText>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_uploadVersion"
                              Label="Version String"
                              Placeholder="e.g. 3.2.0.0"
                              Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_uploadNotes"
                              Label="Release Notes"
                              Placeholder="What changed?"
                              Variant="Variant.Outlined"
                              Lines="3" />
            </MudItem>
            <MudItem xs="12">
                <InputFile OnChange="OnFileSelected" />
            </MudItem>
        </MudGrid>

        @if (!string.IsNullOrEmpty(_uploadError))
        {
            <MudAlert Severity="Severity.Error" Class="mt-3">@_uploadError</MudAlert>
        }
        @if (!string.IsNullOrEmpty(_uploadSuccess))
        {
            <MudAlert Severity="Severity.Success" Class="mt-3">@_uploadSuccess</MudAlert>
        }

        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="UploadVersion" Disabled="_uploading" Class="mt-4">
            @(_uploading ? "Uploading…" : "Upload Version")
        </MudButton>
    </MudPaper>

    <!-- Version history -->
    <MudPaper Class="pa-6">
        <MudText Typo="Typo.h6" Class="mb-4">Version History</MudText>
        @if (_versions.Count == 0)
        {
            <MudText Color="Color.Secondary">No versions uploaded yet.</MudText>
        }
        else
        {
            <MudTable Items="_versions" Hover="true" Striped="true">
                <HeaderContent>
                    <MudTh>Version</MudTh>
                    <MudTh>Uploaded</MudTh>
                    <MudTh>Size</MudTh>
                    <MudTh>SHA-256</MudTh>
                    <MudTh>Notes</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudChip T="string" Color="@(context == _versions[0] ? Color.Success : Color.Default)" Size="Size.Small">
                            @context.VersionString
                        </MudChip>
                    </MudTd>
                    <MudTd>@context.UploadedAt.ToString("yyyy-MM-dd HH:mm")</MudTd>
                    <MudTd>@FormatSize(context.FileSizeBytes)</MudTd>
                    <MudTd>
                        <MudTooltip Text="@context.Sha256Hash">
                            <code>@context.Sha256Hash[..12]…</code>
                        </MudTooltip>
                    </MudTd>
                    <MudTd>@context.ReleaseNotes</MudTd>
                    <MudTd>
                        <MudStack Row="true" Spacing="1">
                            <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small"
                                           Href="@($"/api/update/download/{_app.Slug}/{context.VersionString}")"
                                           Target="_blank" />
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                       OnClick="() => DeleteVersion(context.Id, context == _versions[0])">
                                @(context == _versions[0] ? "Rollback" : "Delete")
                            </MudButton>
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>
}

@code {
    [Parameter] public string Slug { get; set; } = "";

    private AppSummary? _app;
    private List<VersionSummary> _versions = [];

    private string _uploadVersion = "";
    private string _uploadNotes = "";
    private IBrowserFile? _selectedFile;
    private bool _uploading;
    private string? _uploadError;
    private string? _uploadSuccess;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _app = await Updates.GetAppBySlugAsync(Slug);
        _versions = await Updates.GetVersionHistoryAsync(Slug);
    }

    private void OnFileSelected(InputFileChangeEventArgs e) => _selectedFile = e.File;

    private async Task UploadVersion()
    {
        _uploadError = null;
        _uploadSuccess = null;

        if (string.IsNullOrWhiteSpace(_uploadVersion))
        { _uploadError = "Version string is required."; return; }
        if (_selectedFile is null)
        { _uploadError = "Please select a file."; return; }

        _uploading = true;
        try
        {
            await using var stream = _selectedFile.OpenReadStream(maxAllowedSize: 500 * 1024 * 1024);
            var result = await Updates.UploadVersionAsync(
                Slug, _uploadVersion, _uploadNotes, stream, _selectedFile.Name);

            if (result.Success)
            {
                _uploadSuccess = $"Version {result.Version!.VersionString} uploaded successfully.";
                _uploadVersion = "";
                _uploadNotes = "";
                _selectedFile = null;
                await LoadData();
            }
            else
            {
                _uploadError = result.Error;
            }
        }
        catch (Exception ex)
        {
            _uploadError = $"Upload failed: {ex.Message}";
        }
        finally
        {
            _uploading = false;
        }
    }

    private async Task DeleteVersion(int versionId, bool isLatest)
    {
        await Updates.DeleteVersionAsync(versionId);
        await LoadData();
        if (isLatest)
            _uploadSuccess = "Rolled back — previous version is now current.";
    }

    private async Task DeleteApp()
    {
        if (_app is null) return;
        await Updates.DeleteAppAsync(_app.Id);
        Nav.NavigateTo("/");
    }

    private static string FormatSize(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes / 1024.0 / 1024.0:F1} MB"
    };
}
